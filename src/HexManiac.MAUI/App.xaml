<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HavenSoft.HexManiac.MAUI.App">
  <Application.Resources>
    <ResourceDictionary>
      <!-- Default dark theme - overwritten at runtime by EditorViewModel.Theme -->
      <Color x:Key="BackgroundColor">#1E1E2E</Color>
      <Color x:Key="PrimaryColor">#CBA6F7</Color>
      <Color x:Key="SecondaryColor">#89B4FA</Color>
      <Color x:Key="TextColor">#CDD6F4</Color>
      <Color x:Key="AccentColor">#F38BA8</Color>
      <Color x:Key="ErrorColor">#F38BA8</Color>
      <Color x:Key="Data1Color">#A6E3A1</Color>
      <Color x:Key="Data2Color">#94E2D5</Color>
      <Color x:Key="Stream1Color">#FAB387</Color>
      <Color x:Key="Stream2Color">#F9E2AF</Color>
      <Color x:Key="EditBgColor">#313244</Color>

      <!-- Global styles -->
      <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
      </Style>
      <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
        <Setter Property="FontFamily" Value="Consolas" />
      </Style>
      <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
        <Setter Property="BackgroundColor" Value="{StaticResource EditBgColor}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SecondaryColor}" />
        <Setter Property="FontFamily" Value="Consolas" />
      </Style>
      <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="TextColor" Value="{StaticResource BackgroundColor}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="Padding" Value="8,4" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>
