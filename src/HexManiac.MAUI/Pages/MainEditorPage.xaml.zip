<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:HavenSoft.HexManiac.MAUI.Controls"
             x:Class="HavenSoft.HexManiac.MAUI.Pages.MainEditorPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundColor}">

  <ContentPage.Resources>
    <!-- Toolbar button style -->
    <Style x:Key="ToolbarBtn" TargetType="Button">
      <Setter Property="BackgroundColor" Value="Transparent"/>
      <Setter Property="TextColor"       Value="{StaticResource SecondaryColor}"/>
      <Setter Property="FontFamily"      Value="Consolas"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Padding"         Value="10,6"/>
      <Setter Property="CornerRadius"    Value="4"/>
    </Style>
    <!-- Tab button style -->
    <Style x:Key="TabBtn" TargetType="Button">
      <Setter Property="BackgroundColor" Value="Transparent"/>
      <Setter Property="TextColor"       Value="{StaticResource TextColor}"/>
      <Setter Property="FontFamily"      Value="Consolas"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Padding"         Value="8,4"/>
      <Setter Property="CornerRadius"    Value="0"/>
    </Style>
  </ContentPage.Resources>

  <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

    <!-- ═══ Row 0 : Top toolbar ══════════════════════════════════════════════ -->
    <ScrollView Grid.Row="0" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
      <HorizontalStackLayout Spacing="0" Padding="4,2" BackgroundColor="{StaticResource EditBgColor}">

        <Button Text="Open"   Style="{StaticResource ToolbarBtn}" Clicked="OnOpenClicked"/>
        <Button Text="Save"   Style="{StaticResource ToolbarBtn}" Clicked="OnSaveClicked"/>
        <Button Text="SaveAs" Style="{StaticResource ToolbarBtn}" Clicked="OnSaveAsClicked"/>
        <BoxView WidthRequest="1" BackgroundColor="{StaticResource SecondaryColor}" Margin="4,4"/>
        <Button Text="Undo"   Style="{StaticResource ToolbarBtn}" Clicked="OnUndoClicked"/>
        <Button Text="Redo"   Style="{StaticResource ToolbarBtn}" Clicked="OnRedoClicked"/>
        <BoxView WidthRequest="1" BackgroundColor="{StaticResource SecondaryColor}" Margin="4,4"/>
        <Button Text="Find"   Style="{StaticResource ToolbarBtn}" Clicked="OnFindClicked"/>
        <Button Text="Goto"   Style="{StaticResource ToolbarBtn}" Clicked="OnGotoClicked"/>
        <BoxView WidthRequest="1" BackgroundColor="{StaticResource SecondaryColor}" Margin="4,4"/>
        <Button Text="+"      Style="{StaticResource ToolbarBtn}" Clicked="OnNewTabClicked"
                TextColor="{StaticResource PrimaryColor}"/>
      </HorizontalStackLayout>
    </ScrollView>

    <!-- ═══ Row 1 : Tab strip ════════════════════════════════════════════════ -->
    <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                BackgroundColor="{StaticResource EditBgColor}">
      <HorizontalStackLayout x:Name="TabStrip" Spacing="0" Padding="0"/>
    </ScrollView>

    <!-- ═══ Row 2 : Hex content (SkiaSharp canvas) ═══════════════════════════ -->
    <Grid Grid.Row="2">
      <controls:HexContentView x:Name="HexView" />

      <!-- Goto overlay (hidden by default) -->
      <Grid x:Name="GotoOverlay" IsVisible="False" BackgroundColor="#BB1E1E2E"
            HorizontalOptions="Center" VerticalOptions="Start" Margin="0,16,0,0"
            WidthRequest="300">
        <VerticalStackLayout Padding="16" Spacing="8">
          <Label Text="Go to address" TextColor="{StaticResource PrimaryColor}" FontSize="16"/>
          <Entry x:Name="GotoEntry" Placeholder="000000" Keyboard="Text"
                 ReturnCommand="{Binding GotoViewModel.MoveToAddress}"
                 ReturnCommandParameter="{Binding Source={x:Reference GotoEntry}, Path=Text}"/>
          <HorizontalStackLayout Spacing="8">
            <Button Text="Go"     Clicked="OnGotoConfirm"/>
            <Button Text="Cancel" Clicked="OnGotoCancel"
                    BackgroundColor="Transparent" TextColor="{StaticResource TextColor}"/>
          </HorizontalStackLayout>
        </VerticalStackLayout>
      </Grid>

      <!-- Find overlay -->
      <Grid x:Name="FindOverlay" IsVisible="False" BackgroundColor="#BB1E1E2E"
            HorizontalOptions="Center" VerticalOptions="Start" Margin="0,16,0,0"
            WidthRequest="320">
        <VerticalStackLayout Padding="16" Spacing="8">
          <Label Text="Find" TextColor="{StaticResource PrimaryColor}" FontSize="16"/>
          <Entry x:Name="FindEntry" Placeholder="search bytes or text" Keyboard="Text"/>
          <HorizontalStackLayout Spacing="8">
            <Button Text="Find Next" Clicked="OnFindNext"/>
            <Button Text="Find Prev" Clicked="OnFindPrev"/>
            <Button Text="✕" Clicked="OnFindCancel"
                    BackgroundColor="Transparent" TextColor="{StaticResource TextColor}"/>
          </HorizontalStackLayout>
        </VerticalStackLayout>
      </Grid>
    </Grid>

    <!-- ═══ Row 3 : Status / address bar ═════════════════════════════════════ -->
    <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Padding="8,4"
          BackgroundColor="{StaticResource EditBgColor}">
      <Label Grid.Column="0" x:Name="AddressLabel"
             Text="000000" TextColor="{StaticResource SecondaryColor}" FontSize="12"/>
      <Label Grid.Column="1" x:Name="StatusLabel"
             HorizontalOptions="Center" FontSize="12"/>
      <Label Grid.Column="2" x:Name="MessageLabel"
             TextColor="{StaticResource AccentColor}" FontSize="12"/>
    </Grid>

    <!-- ═══ Row 4 : Error / notification bar (hidden when empty) ════════════ -->
    <Grid Grid.Row="4" x:Name="ErrorBar" IsVisible="False"
          BackgroundColor="{StaticResource ErrorColor}" Padding="8,4">
      <Label x:Name="ErrorLabel" TextColor="White" FontSize="12"/>
    </Grid>

  </Grid>
</ContentPage>
