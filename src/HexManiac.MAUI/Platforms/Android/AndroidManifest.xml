<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-sdk android:minSdkVersion="26" android:targetSdkVersion="35" />

  <!-- File access permissions for opening/saving GBA ROMs -->
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
  <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
  <!-- Scoped storage / document access (API 30+) is handled via SAF (Storage Access Framework) -->

  <application
    android:allowBackup="true"
    android:icon="@mipmap/appicon"
    android:label="HexManiacAdvance"
    android:roundIcon="@mipmap/appicon_round"
    android:supportsRtl="true"
    android:theme="@style/Maui.SplashTheme">

    <!-- File associations: .gba and .hma files open the app -->
    <activity android:name="crc64..." android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <data android:mimeType="application/octet-stream" android:pathPattern=".*\\.gba" />
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <data android:mimeType="*/*" android:pathPattern=".*\\.hma" />
      </intent-filter>
    </activity>

  </application>

</manifest>
